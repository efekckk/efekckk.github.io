---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../ProjectCard.astro';
import PixelIcon from '../PixelIcon.astro';
import HudRail from '../HudRail.astro';
import { branches, branchKeys } from '../../data/branches';
import { useTranslations, localizePath, otherLang, entrySlug } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = (await getCollection('projects', (e) => e.id.startsWith(`${lang}/`)))
  .sort((a, b) => a.data.order - b.data.order);
const allPosts = (await getCollection('blog', (e) => e.id.startsWith(`${lang}/`)))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const posts = allPosts.slice(0, 3);

const dateFmt = new Intl.DateTimeFormat(lang === 'tr' ? 'tr-TR' : 'en-US', {
  year: 'numeric',
  month: 'short',
});

const status: Record<Lang, string> = {
  en: 'OPEN TO WORK',
  tr: 'YENİ FIRSATLARA AÇIK',
};

const analyze: Record<Lang, { info: string; scan: string; alert: string; ok: string }> = {
  en: {
    info: 'loading 3 branches... OK',
    scan: 'running modified z-score (MAD) on subject...',
    alert: 'anomaly detected: 3 careers in 1 person (z = 4.2)',
    ok: 'false_positive: false — confirmed by production data',
  },
  tr: {
    info: '3 branch yükleniyor... OK',
    scan: 'denek üzerinde modified z-score (MAD) çalışıyor...',
    alert: 'anomali tespit edildi: tek kişide 3 kariyer (z = 4.2)',
    ok: 'false_positive: false — üretim verisiyle doğrulandı',
  },
};

const demo: Record<Lang, { hint: string; count: string; scanning: string; warning: string }> = {
  en: {
    hint: 'your pointer movement is a live metric — my MAD-based engine flags the spikes',
    count: 'anomalies caught',
    scanning: 'scanning… all clear',
    warning: 'WARNING: anomaly detected',
  },
  tr: {
    hint: 'fare/parmak hareketin canlı bir metrik — MAD tabanlı motorum sapmaları yakalar',
    count: 'yakalanan anomali',
    scanning: 'tarama sürüyor… temiz',
    warning: 'UYARI: anomali tespit edildi',
  },
};

const skills: { label: Record<Lang, string>; v: number; joke?: boolean }[] = [
  { label: { en: 'SQL · Python', tr: 'SQL · Python' }, v: 92 },
  { label: { en: 'Power BI · Looker', tr: 'Power BI · Looker' }, v: 88 },
  { label: { en: 'RAG · MCP · n8n', tr: 'RAG · MCP · n8n' }, v: 85 },
  { label: { en: 'Airflow · ETL', tr: 'Airflow · ETL' }, v: 82 },
  { label: { en: 'Kotlin · SwiftUI', tr: 'Kotlin · SwiftUI' }, v: 78 },
  { label: { en: 'Escaping Excel', tr: "Excel'den kaçış" }, v: 97, joke: true },
];
---
<BaseLayout
  lang={lang}
  title={t('meta.home.title')}
  description={t('meta.home.desc')}
  altPath={localizePath(otherLang(lang), '/')}
>
  <div class="console-grid">
  <HudRail lang={lang} status={status[lang]} projectCount={projects.length} postCount={allPosts.length} />
  <div class="console-main">
  <header class="hero-head">
    <div>
      <h1 class="hero-name">EFECAN <span class="grad">KÜÇÜK</span></h1>
      <p class="hero-tag">{t('hero.tag')}</p>
    </div>
  </header>

  <section class="terminal" id="branches">
    <div class="prompt">efecan@istanbul ~ $ git branch -a</div>
    {branchKeys.map((key) => (
      <a class="branch-line" data-branch={key} href={`#${branches[key].anchor}`}>
        <span class="star">{key === 'data' ? '*' : ' '}</span>
        <PixelIcon name={key} size={2} />
        <span class="branch-name">{branches[key].name}</span>
        <span class="branch-comment">{branches[key].comment[lang]}</span>
      </a>
    ))}
    <div class="analyze-seq">
      <div class="prompt" data-line>efecan@istanbul ~ $ <span class="cmd-text">python analyze.py --target=efecan</span></div>
      <div class="out out-info" data-line>[ INFO ]&nbsp; {analyze[lang].info}</div>
      <div class="out out-info" data-line>[ SCAN ]&nbsp; {analyze[lang].scan}</div>
      <div class="out out-alert" data-line>[ALERT ]&nbsp; {analyze[lang].alert}</div>
      <div class="out out-ok" data-line>[ &nbsp;OK&nbsp; ]&nbsp; {analyze[lang].ok}</div>
      <div class="prompt" data-line>efecan@istanbul ~ $ <span class="cursor">▊</span></div>
    </div>
  </section>

  <div class="hero-actions">
    <a class="btn btn-primary" href={localizePath(lang, '/projects')}>{t('btn.projects')}</a>
    <a class="btn" href="/cv.pdf" download>{t('btn.cv')}</a>
  </div>

  <section class="anomaly-demo" id="live">
    <p class="eyebrow">$ ./anomaly-engine --live --input=pointer</p>
    <h2 class="section-title">{t('section.live')}</h2>
    <div class="demo-panel">
      <canvas id="anomaly-canvas" width="600" height="160"></canvas>
      <div
        class="demo-status"
        id="anomaly-status"
        data-scanning={demo[lang].scanning}
        data-warning={demo[lang].warning}
      >{demo[lang].scanning}</div>
      <div class="demo-meta">
        <span class="demo-hint">{demo[lang].hint}</span>
        <span class="demo-count">{demo[lang].count}: <b id="anomaly-count">0</b></span>
      </div>
    </div>
  </section>

  {branchKeys.map((key) => {
    const list = projects.filter((p) => p.data.branch === key);
    return list.length > 0 && (
      <section id={branches[key].anchor}>
        <p class="eyebrow">$ ls projects/ --branch={branches[key].name}</p>
        <h2 class="section-title" data-branch={key}>
          <PixelIcon name={key} size={2} />{branches[key].title[lang]}
        </h2>
        <div class="grid">
          {list.map((p) => <ProjectCard project={p} lang={lang} />)}
        </div>
      </section>
    );
  })}

  <section id="skills">
    <p class="eyebrow">$ cat skills.txt --bars</p>
    <h2 class="section-title">{t('section.skills')}</h2>
    <div class="skills">
      {skills.map((s) => (
        <div class="skill-row" data-joke={s.joke ? 'true' : undefined}>
          <span class="skill-name">{s.label[lang]}</span>
          <span class="skill-bar"><i style={`--w:${s.v}%`}></i></span>
          <span class="skill-val">{s.v}%</span>
        </div>
      ))}
    </div>
  </section>

  <section id="about">
    <p class="eyebrow">{t('home.cmd.about')}</p>
    <h2 class="section-title">{t('section.about')}</h2>
    <p style="max-width: 620px; color: var(--muted); font-size: 15px;">
      {t('home.about.text')}
    </p>
    <a href={localizePath(lang, '/about')}>{t('home.about.link')}</a>
  </section>

  <section id="posts">
    <p class="eyebrow">{t('home.cmd.blog')}</p>
    <h2 class="section-title">{t('section.posts')}</h2>
    {posts.map((post) => (
      <a
        class="post-row"
        data-branch={post.data.branch}
        href={localizePath(lang, `/blog/${entrySlug(post.id)}`)}
      >
        <span>
          <span class="post-tag">[{post.data.branch}]</span>
          {post.data.title}
        </span>
        <span class="post-date mono">{dateFmt.format(post.data.date)}</span>
      </a>
    ))}
    <p><a href={localizePath(lang, '/blog')}>{t('home.blog.link')}</a></p>
  </section>
  </div>
  </div>
</BaseLayout>

<script>
  // ── self-typing analyze sequence ─────────────────────────
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const seq = document.querySelector('.analyze-seq');

  if (seq && !reduced) {
    const lines = [...seq.querySelectorAll<HTMLElement>('[data-line]')];
    const cmdText = seq.querySelector<HTMLElement>('.cmd-text');
    const fullCmd = cmdText?.textContent ?? '';
    lines.forEach((l) => (l.style.display = 'none'));
    if (cmdText) cmdText.textContent = '';

    const showLine = (i: number) => {
      if (i >= lines.length) return;
      lines[i].style.display = '';
      setTimeout(() => showLine(i + 1), i === 0 ? 0 : 260);
    };

    setTimeout(() => {
      lines[0].style.display = '';
      let c = 0;
      const typeChar = () => {
        if (!cmdText) return;
        if (c < fullCmd.length) {
          cmdText.textContent = fullCmd.slice(0, ++c);
          setTimeout(typeChar, 28);
        } else {
          setTimeout(() => showLine(1), 350);
        }
      };
      typeChar();
    }, 900);
  }

  // ── live anomaly engine (Modified Z-Score over MAD) ──────
  const canvas = document.getElementById('anomaly-canvas') as HTMLCanvasElement | null;
  const countEl = document.getElementById('anomaly-count');

  if (canvas && countEl) {
    const ctx = canvas.getContext('2d')!;
    const ORANGE = { mid: '#ffa657' };

    const SPRITES = {
      invader: ['..#..#..', '...##...', '..####..', '.##..##.', '########', '#.####.#', '#.#..#.#', '.#....#.'],
      bot: [
        '....a.....',
        '.ffffffff.',
        '.feeeeeef.',
        '.fegeegef.',
        '.feggggef.',
        '.ffffffff.',
        '...tttt...',
        '..ttcctt..',
        '..t....t..',
      ],
    };

    const BOT_PAL: Record<string, string> = {
      a: '#ffa657',
      f: '#38414d',
      e: '#0b1016',
      g: '#39d353',
      t: '#2ea043',
      c: '#58c6ff',
    };

    const drawSprite = (
      map: string[],
      x: number,
      y: number,
      s: number,
      palette: Record<string, string>,
      skip?: string
    ) => {
      map.forEach((row, ry) => {
        [...row].forEach((c, rx) => {
          const color = palette[c];
          if (!color || c === skip) return;
          ctx.fillStyle = color;
          ctx.fillRect(x + rx * s, y + ry * s, s, s);
        });
      });
    };

    let starSeed = 42;
    const srand = () => (starSeed = (starSeed * 1103515245 + 12345) & 0x7fffffff) / 0x7fffffff;
    const stars = Array.from({ length: 26 }, () => ({
      x: Math.floor(srand() * 600),
      y: Math.floor(srand() * 80),
      blink: srand() < 0.35,
    }));

    let tickCount = 0;
    const WINDOW = 40;
    const THRESHOLD = 3.5;
    const MAD_FLOOR = 2;
    const REFRACTORY = 12;
    const samples: { v: number; z: number; anomaly: boolean }[] = [];
    let speed = 0;
    let lastX: number | null = null;
    let lastY: number | null = null;
    let anomalies = 0;
    let cooldown = 0;

    const onMove = (x: number, y: number) => {
      if (lastX !== null && lastY !== null) {
        speed += Math.hypot(x - lastX, y - lastY);
      }
      lastX = x;
      lastY = y;
    };
    addEventListener('mousemove', (e) => onMove(e.clientX, e.clientY), { passive: true });
    addEventListener('touchmove', (e) => onMove(e.touches[0].clientX, e.touches[0].clientY), { passive: true });

    const median = (a: number[]) => {
      const s = [...a].sort((x, y) => x - y);
      const m = s.length >> 1;
      return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2;
    };

    const statusEl = document.getElementById('anomaly-status');

    const tick = () => {
      // log-compress pointer speed so steady motion is a band, only jerks spike
      let v = Math.log1p(speed) * 11 + Math.random() * 4;
      if (reduced === false && Math.random() < 0.008) v += 60 + Math.random() * 40;
      speed = 0;

      let anomaly = false;
      let z = 0;
      const recent = samples.slice(-WINDOW).map((s) => s.v);
      if (recent.length >= 10) {
        const med = median(recent);
        const mad = Math.max(median(recent.map((x) => Math.abs(x - med))), MAD_FLOOR);
        z = (0.6745 * (v - med)) / mad;
        anomaly = Math.abs(z) > THRESHOLD && cooldown === 0;
      }
      if (anomaly) {
        cooldown = REFRACTORY;
        countEl.textContent = String(++anomalies);
        if (statusEl) {
          statusEl.textContent = `▲ ${statusEl.dataset.warning} (z = ${z.toFixed(1)})`;
          statusEl.classList.add('alert');
        }
      } else if (cooldown > 0) {
        cooldown--;
        if (cooldown === 0 && statusEl) {
          statusEl.textContent = statusEl.dataset.scanning ?? '';
          statusEl.classList.remove('alert');
        }
      }
      samples.push({ v, z, anomaly });
      if (samples.length > 60) samples.shift();
      tickCount++;
      draw();
    };

    const draw = () => {
      const W = canvas.width;
      const H = canvas.height;
      const padY = 16;
      const left = 38;
      const right = W - 12;
      const zMin = -5;
      const zMax = 6.5;
      const yOf = (zv: number) => {
        const c = Math.max(zMin, Math.min(zMax, zv));
        return padY + ((zMax - c) / (zMax - zMin)) * (H - 2 * padY);
      };
      ctx.clearRect(0, 0, W, H);

      stars.forEach((st, i) => {
        if (st.blink && (tickCount + i) % 9 < 3) return;
        ctx.fillStyle = 'rgba(230, 237, 243, 0.09)';
        ctx.fillRect(st.x, (st.y * 1.6) % H, 2, 2);
      });

      ctx.font = "10px 'IBM Plex Mono', monospace";
      const gridlines: [string, number, string][] = [
        ['+3.5', 3.5, 'rgba(255, 166, 87, 0.35)'],
        ['0', 0, 'rgba(230, 237, 243, 0.12)'],
        ['-3.5', -3.5, 'rgba(255, 166, 87, 0.35)'],
      ];
      gridlines.forEach(([label, zv, color]) => {
        const y = yOf(zv);
        ctx.strokeStyle = color;
        ctx.lineWidth = 1;
        ctx.setLineDash(zv === 0 ? [] : [5, 5]);
        ctx.beginPath();
        ctx.moveTo(left, y);
        ctx.lineTo(right, y);
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = 'rgba(139, 148, 158, 0.8)';
        ctx.fillText(label, 6, y + 3);
      });

      const step = (right - left) / 59;
      const pts = samples.map((s, i) => ({
        x: right - (samples.length - 1 - i) * step,
        y: yOf(s.z),
        a: s.anomaly,
      }));
      if (pts.length < 2) return;

      ctx.strokeStyle = '#39d353';
      ctx.lineWidth = 2;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';
      ctx.shadowColor = 'rgba(57, 211, 83, 0.55)';
      ctx.shadowBlur = 10;
      ctx.beginPath();
      pts.forEach((p, i) => (i ? ctx.lineTo(p.x, p.y) : ctx.moveTo(p.x, p.y)));
      ctx.stroke();
      ctx.shadowBlur = 0;

      pts.forEach((p) => {
        if (!p.a) return;
        ctx.fillStyle = '#ff6b50';
        ctx.shadowColor = 'rgba(255, 107, 80, 0.9)';
        ctx.shadowBlur = 14;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 3.5, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
        drawSprite(SPRITES.invader, p.x - 8, Math.max(2, p.y - 30), 2, { '#': ORANGE.mid });
      });

      const last = pts[pts.length - 1];
      if (last && !last.a) {
        const bounce = tickCount % 4 < 2 ? 0 : 2;
        const blinkOff = tickCount % 6 < 2 ? 'a' : undefined;
        drawSprite(SPRITES.bot, last.x - 16, last.y - 20 - bounce, 2, BOT_PAL, blinkOff);
      }
    };

    setInterval(tick, 140);
  }
</script>

---
interface Props {
  name: 'data' | 'mobile' | 'ai';
  size?: number;
}
const { name, size = 2 } = Astro.props;

const GLYPHS: Record<Props['name'], string[]> = {
  data: [
    '........',
    '......##',
    '......##',
    '...##.##',
    '...##.##',
    '##.##.##',
    '##.##.##',
    '########',
  ],
  mobile: [
    '..####..',
    '.######.',
    '.#....#.',
    '.#....#.',
    '.#....#.',
    '.#....#.',
    '.##..##.',
    '..####..',
  ],
  ai: [
    '..#..#..',
    '...##...',
    '..####..',
    '.##..##.',
    '########',
    '#.####.#',
    '#.#..#.#',
    '.#....#.',
  ],
};

const shadows: string[] = [];
GLYPHS[name].forEach((row, y) => {
  [...row].forEach((cell, x) => {
    if (cell === '#') shadows.push(`${x * size}px ${y * size}px 0 0 currentColor`);
  });
});
const total = size * 8;
---
<span class="pixel-icon" aria-hidden="true" style={`width:${total}px;height:${total}px;`}>
  <i style={`width:${size}px;height:${size}px;box-shadow:${shadows.join(',')};`}></i>
</span>

---
interface Props {
  size?: number;
}
const { size = 5 } = Astro.props;

const PALETTE: Record<string, string> = {
  h: '#262d36',
  s: '#e8b88a',
  g: '#58c6ff',
  d: '#0a0d12',
  t: '#39d353',
};

const MAP = [
  '................',
  '....hhhhhhhh....',
  '...hhhhhhhhhh...',
  '..hhhhhhhhhhhh..',
  '..hhsssssssshh..',
  '..hssssssssssh..',
  '.hsggggssggggsh.',
  '.hsgddgssgddgsh.',
  '..hssssssssssh..',
  '..ssssssssssss..',
  '...ssssddssss...',
  '....ssssssss....',
  '......ssss......',
  '....tttttttt....',
  '..tttttttttttt..',
  '.tttttttttttttt.',
];

const shadows: string[] = [];
MAP.forEach((row, y) => {
  [...row].forEach((cell, x) => {
    const color = PALETTE[cell];
    if (color) shadows.push(`${x * size}px ${y * size}px 0 0 ${color}`);
  });
});
const total = size * 16;
---
<span class="pixel-avatar" aria-hidden="true" style={`width:${total}px;height:${total}px;`}>
  <i style={`width:${size}px;height:${size}px;box-shadow:${shadows.join(',')};`}></i>
</span>

---
interface Props {
  size?: number;
}
const { size = 5 } = Astro.props;

const PALETTE: Record<string, string> = {
  f: '#38414d',
  e: '#0b1016',
  g: '#39d353',
  l: '#1d2836',
  a: '#ffa657',
  T: '#56d364',
  t: '#2ea043',
  c: '#58c6ff',
};

const MAP = [
  '.........a........',
  '.........f........',
  '..ffffffffffffff..',
  '..felleeeeeeeeef..',
  '..feeggeeeeggeef..',
  '..feeeeeeeeeeeef..',
  '..feegeeeeeegeef..',
  '..feeeggggggeeef..',
  '..feeeeeeeeeeeef..',
  '..ffffffffffffff..',
  '.......ff.........',
  '....TTTTTTTTTT....',
  '....ttcctttttt....',
  '....tttttttttt....',
  '.....tt....tt.....',
  '.....ff....ff.....',
];

const shadows: string[] = [];
const antennaShadows: string[] = [];
MAP.forEach((row, y) => {
  [...row].forEach((cell, x) => {
    const color = PALETTE[cell];
    if (!color) return;
    const px = `${x * size}px ${y * size}px 0 0 ${color}`;
    (cell === 'a' ? antennaShadows : shadows).push(px);
  });
});
const width = size * MAP[0].length;
const height = size * MAP.length;
---
<span class="pixel-avatar" aria-hidden="true" style={`width:${width}px;height:${height}px;`}>
  <i style={`width:${size}px;height:${size}px;box-shadow:${shadows.join(',')};`}></i>
  <i class="antenna" style={`width:${size}px;height:${size}px;box-shadow:${antennaShadows.join(',')};`}></i>
</span>

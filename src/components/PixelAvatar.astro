---
interface Props {
  size?: number;
}
const { size = 5 } = Astro.props;

const PALETTE: Record<string, string> = {
  h: '#332821',
  s: '#e0b48c',
  n: '#c89a72',
  d: '#0a0d12',
  b: '#5a4733',
  m: '#b07055',
  k: '#232a34',
  p: '#7a4f33',
  q: '#a4744a',
};

const MAP = [
  '..................',
  '.....hhhhhhhh.....',
  '....hhhhhhhhhh....',
  '...hhhhhhhhhhhh...',
  '....hhsssssshh....',
  '....hssssssssh....',
  '....hshhsshhsh....',
  '....hssdssdssh....',
  '....hssssssssh....',
  '....hsssnnsssh....',
  '....hbssssssbh....',
  '....hbsbbbbsbh....',
  '....hbbsmmsbbh....',
  '.....bbbbbbbb.....',
  '.......ssss.......',
  '...pqppkkkkppqp...',
  '..ppqppkkkkppqpp..',
  '.pqppqpkkkkpqppqp.',
];

const shadows: string[] = [];
MAP.forEach((row, y) => {
  [...row].forEach((cell, x) => {
    const color = PALETTE[cell];
    if (color) shadows.push(`${x * size}px ${y * size}px 0 0 ${color}`);
  });
});
const width = size * MAP[0].length;
const height = size * MAP.length;
---
<span class="pixel-avatar" aria-hidden="true" style={`width:${width}px;height:${height}px;`}>
  <i style={`width:${size}px;height:${size}px;box-shadow:${shadows.join(',')};`}></i>
</span>
